  "external_type_links": {
    "BaseModel": "https://docs.pydantic.dev/latest/api/base_model/#BaseModel"
  },
  "manual_types": {
    "JSONSchemaInput": {
      "description": "Input type for JSON schema parameters. Can be either a Pydantic model class (automatically converted to JSON Schema) or a raw JSON Schema dictionary.",
      "definition": "Union[type[BaseModel], dict[str, Any]]"
    },
    "Entity": {
      "description": "Union type representing either a company or person entity. See CompanyEntity and PersonEntity for details.",
      "definition": "Union[CompanyEntity, PersonEntity]"
    },
    "ResearchModel": {
      "description": "The model to use for research tasks.",
      "definition": "Literal['exa-research-fast', 'exa-research', 'exa-research-pro']"
    },
    "ResearchEvent": {
      "description": "Union of all research event types that can be streamed during research execution.",
      "definition": "Union[ResearchMetaEvent, ResearchPlanEvent, ResearchTaskEvent]"
    },
    "ResearchDto": {
      "description": "Union of all research status types. The actual type depends on the task status.",
      "definition": "Union[ResearchPendingDto, ResearchRunningDto, ResearchCompletedDto, ResearchCanceledDto, ResearchFailedDto]"
    },
    "SearchMonitorStatus": {
      "description": "Status of a Search Monitor.",
      "definition": "Literal['active', 'paused', 'disabled']"
    },
    "SearchMonitorRunStatus": {
      "description": "Status of a Search Monitor run.",
      "definition": "Literal['pending', 'running', 'completed', 'failed', 'cancelled']"
    },
    "SearchMonitorRunFailReason": {
      "description": "Reason a Search Monitor run failed.",
      "definition": "Literal['api_key_invalid', 'insufficient_credits', 'invalid_params', 'rate_limited', 'search_unavailable', 'search_failed', 'internal_error']"
    },
    "SearchMonitorWebhookEvent": {
      "description": "Webhook event types for Search Monitors.",
      "definition": "Literal['monitor.created', 'monitor.updated', 'monitor.deleted', 'monitor.run.created', 'monitor.run.completed']"
    }
  },
  "exclude_type_aliases": ["LIVECRAWL_OPTIONS"],
  "type_field_overrides": {
    "ContentsOptions": [
      {"name": "text", "type": "Union[TextContentsOptions, Literal[True]]", "description": "Options for text extraction, or True for defaults."},
      {"name": "highlights", "type": "Union[HighlightsContentsOptions, Literal[True]]", "description": "Options for highlight extraction, or True for defaults."},
      {"name": "summary", "type": "Union[SummaryContentsOptions, Literal[True]]", "description": "Options for summary generation, or True for defaults."},
      {"name": "context", "type": "Union[ContextContentsOptions, Literal[True]]", "description": "Deprecated. Use `highlights` or `text` instead. Will be removed in a future version."},
      {"name": "max_age_hours", "type": "int", "description": "Maximum age of cached content in hours. If content is older, it will be fetched fresh. Special values: 0 = always fetch fresh content, -1 = never fetch fresh (use cached content only). Example: 168 = fetch fresh for pages older than 7 days."},
      {"name": "subpages", "type": "int", "description": "Number of subpages to crawl."},
      {"name": "subpage_target", "type": "Union[str, List[str]]", "description": "Target subpage path(s) to crawl."},
      {"name": "extras", "type": "ExtrasOptions", "description": "Additional extraction options (links, images)."}
    ]
  }
